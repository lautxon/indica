
// @ts-nocheck
---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Importar canciones de forma segura (sin errores de TypeScript)
let posts = [];
try {
  // @ts-ignore - Ignorar verificación de tipos para simplicidad
  const { getCollection } = await import('astro:content');
  posts = await getCollection('canciones');
  // @ts-ignore
  posts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
} catch (e) {
  // Si no hay contenido, no pasa nada
}
---

<Layout title="Indica - Música Independiente">
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    
    <!-- Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-pink-500 to-red-500 mb-4">
        Indica
      </h1>
      <p class="text-slate-400 text-lg">Música independiente • Hecha con corazón</p>
    </header>

    {/* Lista de canciones */}
    {posts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2">
        {posts.map((post: any) => (
          <article class="bg-slate-800/60 backdrop-blur-sm border border-slate-700 rounded-2xl overflow-hidden hover:border-purple-500/50 transition-colors">
            
            {/* Imagen de portada */}
            {post.data.image && (
              <img 
                src={post.data.image} 
                alt={post.data.title}
                class="w-full h-48 object-cover"
              />
            )}
            
            <div class="p-6">
              <h2 class="text-xl font-bold mb-2 text-white">{post.data.title}</h2>
              <p class="text-slate-400 text-sm mb-4">
                {new Date(post.data.date).toLocaleDateString('es-AR', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </p>
              
              {/* Reproductor / Link */}
              {post.data.audio_url ? (
                <a 
                  href={post.data.audio_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold py-2 px-4 rounded-lg transition-all"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  Escuchar / Ver
                </a>
              ) : (
                <span class="text-slate-500 text-sm">Próximamente...</span>
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      /* Estado vacío: cuando aún no hay canciones */
      <div class="text-center py-12 border-2 border-dashed border-slate-700 rounded-2xl">
        <p class="text-slate-400 text-lg mb-4">🎸 Próximamente: Nuevo material musical</p>
        <p class="text-slate-500 text-sm">
          El músico subirá canciones desde el <a href="/indica/admin/" class="text-purple-400 hover:underline">panel de administración</a>
        </p>
      </div>
    )}

    {/* Footer con link al admin */}
    <footer class="mt-16 text-center text-slate-600 text-sm">
      <a href="/indica/admin/" class="hover:text-purple-400 transition-colors">
        Panel de administración →
      </a>
    </footer>
    
  </main>
</Layout>