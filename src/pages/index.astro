---
// @ts-nocheck
// src/pages/index.astro

let posts = [];
try {
  const { getCollection } = await import('astro:content');
  posts = await getCollection('canciones');
  posts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
} catch (e) {
  // Si no hay contenido, no pasa nada
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/indica/favicon.svg" />
    <title>Indica - Música Independiente</title>
    <!-- Tailwind CDN con configuración explícita -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              slate: { 900: '#0f172a', 800: '#1e293b', 700: '#334155', 600: '#475569', 500: '#64748b', 400: '#94a3b8' },
              purple: { 700: '#7e22ce', 600: '#9333ea', 500: '#a855f7', 400: '#c084fc' },
              pink: { 700: '#be185d', 600: '#db2777', 500: '#ec4899' },
              red: { 500: '#ef4444' }
            }
          }
        }
      }
    </script>
    <style>
      body { background-color: #0f172a; color: white; font-family: system-ui, sans-serif; }
      .gradient-text {
        background: linear-gradient(to right, #c084fc, #ec4899, #ef4444);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
    </style>
  </head>
  <body>
    
    <main style="max-width: 896px; margin: 0 auto; padding: 2rem 1rem;">
      
      <!-- Header -->
      <header style="text-align: center; margin-bottom: 3rem;">
        <h1 class="gradient-text" style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">
          Indica
        </h1>
        <p style="color: #94a3b8; font-size: 1.125rem;">Música independiente • Hecha con corazón</p>
      </header>

      <!-- Lista de canciones -->
      {posts.length > 0 && (
        <div style="display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
          {posts.map((post) => (
            <article style="background: rgba(30, 41, 51, 0.6); backdrop-filter: blur(4px); border: 1px solid #334155; border-radius: 1rem; overflow: hidden; transition: border-color 0.3s;">
              
              {post.data.image && (
                <img 
                  src={post.data.image} 
                  alt={post.data.title}
                  style="width: 100%; height: 12rem; object-fit: cover;"
                />
              )}
              
              <div style="padding: 1.5rem;">
                <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: white;">{post.data.title}</h2>
                <p style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 1rem;">
                  {new Date(post.data.date).toLocaleDateString('es-AR')}
                </p>
                
                {post.data.audio_url && (
                  <a 
                    href={post.data.audio_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="display: inline-block; background: linear-gradient(to right, #9333ea, #db2777); color: white; font-weight: 600; padding: 0.5rem 1rem; border-radius: 0.5rem; text-decoration: none; transition: opacity 0.3s;"
                  >
                    ▶ Escuchar / Ver
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      )}

      <!-- Estado vacío -->
      {posts.length === 0 && (
        <div style="text-align: center; padding: 3rem; border: 2px dashed #334155; border-radius: 1rem;">
          <p style="color: #94a3b8; font-size: 1.125rem; margin-bottom: 1rem;">🎸 Próximamente: Nuevo material musical</p>
          <p style="color: #64748b; font-size: 0.875rem;">
            El músico subirá canciones desde el 
            <a href="/indica/admin/" style="color: #c084fc; text-decoration: underline; margin-left: 0.25rem;">
              panel de administración
            </a>
          </p>
        </div>
      )}

      <!-- Footer -->
      <footer style="margin-top: 4rem; text-align: center; color: #475569; font-size: 0.875rem;">
        <a href="/indica/admin/" style="color: #64748b; text-decoration: none; transition: color 0.3s;">
          Panel de administración →
        </a>
      </footer>
      
    </main>
    
  </body>
</html>
